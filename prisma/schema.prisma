generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ManuscriptFormat {
  TXT
  DOCX
}

enum AnalysisStatus {
  NOT_STARTED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisOutputStatus {
  COMPLETED
  FAILED
}

enum AnalysisPassType {
  PREMISE_GENRE
  STRUCTURE
  PACING
  CHARACTER
  PROSE_STYLE
  COMMERCIAL_MARKET_FIT
  SYNTHESIS
  REWRITE
  CHUNK_ANALYSIS
  CHAPTER_AUDIT
  WHOLE_BOOK_AUDIT
  CORPUS_COMPARISON
  TREND_COMPARISON
  REWRITE_PLAN
  CHAPTER_REWRITE
}

enum AnalysisRunType {
  FULL_AUDIT
  CHAPTER_AUDIT
  CORPUS_COMPARISON
  TREND_COMPARISON
  REWRITE_PLAN
  CHAPTER_REWRITE
}

enum SourceType {
  GUTENBERG
  LITTERATURBANKEN
  SPRAKBANKEN
  DOAB
  GOOGLE_BOOKS
  NYT_BOOKS
  MANUAL
  PRIVATE
}

enum RightsStatus {
  PUBLIC_DOMAIN
  OPEN_LICENSE
  LICENSED
  PRIVATE_REFERENCE
  METADATA_ONLY
  UNKNOWN
}

enum CorpusIngestionStatus {
  QUEUED
  IMPORTED
  CHUNKED
  PROFILED
  FAILED
  METADATA_ONLY
}

enum CorpusAnalysisStatus {
  NOT_STARTED
  RUNNING
  COMPLETED
  FAILED
}

enum EditorialDecisionStatus {
  ACCEPTED
  REJECTED
  DEFERRED
  NEEDS_REVIEW
}

enum EditorialDecisionScope {
  MANUSCRIPT
  CHAPTER
  SCENE
  PARAGRAPH
}

model Source {
  id          String     @id @default(cuid())
  name        String
  type        SourceType
  baseUrl     String?
  rightsNotes String?
  createdAt   DateTime   @default(now())

  books CorpusBook[]

  @@index([type])
}

model CorpusBook {
  id                String                 @id @default(cuid())
  sourceId          String
  title             String
  author            String?
  language          String?
  publicationYear   Int?
  genre             String?
  sourceUrl         String?
  sourceName        String?
  fileName          String?
  fileMimeType      String?
  fileFormat        String?
  rightsStatus      RightsStatus           @default(UNKNOWN)
  licenseType       String?
  allowedUses       Json?
  benchmarkAllowed  Boolean                @default(false)
  benchmarkReady    Boolean                @default(false)
  benchmarkReadyAt  DateTime?
  benchmarkBlockedReason String?
  importProgress    Json?
  fullTextAvailable Boolean                @default(false)
  ingestionStatus   CorpusIngestionStatus  @default(QUEUED)
  analysisStatus    CorpusAnalysisStatus   @default(NOT_STARTED)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  source  Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  text    CorpusBookText?
  chapters CorpusChapter[]
  chunks  CorpusChunk[]
  profile BookProfile?
  importJobs CorpusImportJob[]

  @@index([sourceId])
  @@index([rightsStatus])
  @@index([benchmarkAllowed])
  @@index([benchmarkReady])
  @@index([ingestionStatus])
  @@index([analysisStatus])
  @@index([genre])
  @@index([language])
}

model CorpusBookText {
  id          String   @id @default(cuid())
  bookId      String   @unique
  rawText     String
  cleanedText String
  extractionReport Json?
  wordCount   Int      @default(0)
  cleanedAt   DateTime?
  createdAt   DateTime @default(now())

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model CorpusChapter {
  id           String   @id @default(cuid())
  bookId       String
  order        Int
  chapterIndex Int      @default(0)
  title        String
  heading      String?
  text         String   @default("")
  wordCount    Int      @default(0)
  startOffset  Int?
  endOffset    Int?
  metrics      Json?
  createdAt    DateTime @default(now())

  book   CorpusBook    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chunks CorpusChunk[]

  @@unique([bookId, order])
  @@index([bookId])
  @@index([bookId, chapterIndex])
}

model CorpusChunk {
  id             String                     @id @default(cuid())
  bookId         String
  corpusChapterId String?
  chapterIndex   Int?
  sectionIndex   Int?
  paragraphIndex Int?
  chunkIndex     Int
  text           String
  tokenCount     Int                        @default(0)
  embedding      Unsupported("vector(1536)")?
  embeddingStatus String                     @default("PENDING")
  summary        String?
  metrics        Json?
  createdAt      DateTime                   @default(now())

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter CorpusChapter? @relation(fields: [corpusChapterId], references: [id], onDelete: SetNull)

  @@unique([bookId, chunkIndex])
  @@index([bookId])
  @@index([corpusChapterId])
  @@index([chapterIndex])
  @@index([embeddingStatus])
}

model BookProfile {
  id                       String   @id @default(cuid())
  bookId                   String   @unique
  wordCount                Int      @default(0)
  chapterCount             Int      @default(0)
  avgChapterWords          Int      @default(0)
  medianChapterWords       Int      @default(0)
  minChapterWords          Int      @default(0)
  maxChapterWords          Int      @default(0)
  avgSentenceLength        Float    @default(0)
  dialogueRatio            Float    @default(0)
  questionRatio            Float    @default(0)
  exclamationRatio         Float    @default(0)
  expositionRatio          Float    @default(0)
  actionRatio              Float    @default(0)
  introspectionRatio       Float    @default(0)
  lexicalDensity           Float    @default(0)
  paragraphLengthDistribution Json?
  sentenceLengthDistribution  Json?
  repeatedTerms            Json?
  chapterLengthCurve       Json?
  povEstimate              String?
  tenseEstimate            String?
  openingHookType          String?
  pacingCurve              Json?
  emotionalIntensityCurve  Json?
  conflictDensityCurve     Json?
  chapterEndingPatterns    Json?
  dominantSceneModes       Json?
  narrativeDistance        String?
  styleFingerprint         Json?
  dialogueStyle            Json?
  expositionStyle          Json?
  genreMarkers             Json?
  tropeMarkers             Json?
  literaryCraftLessons     Json?
  deterministicMetrics     Json?
  aiMetrics                Json?
  createdAt                DateTime @default(now())

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model CorpusImportJob {
  id          String    @id @default(cuid())
  bookId      String
  status      String    @default("QUEUED")
  currentStep String    @default("uploaded")
  progress    Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([status])
  @@index([currentStep])
  @@index([createdAt])
}

model TrendSignal {
  id            String   @id @default(cuid())
  source        String
  title         String?
  author        String?
  genre         String?
  category      String?
  rank          Int?
  listName      String?
  signalDate    DateTime?
  description   String?
  blurb         String?
  reviewSnippet String?
  externalUrl   String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([source])
  @@index([genre])
  @@index([category])
  @@index([signalDate])
  @@index([rank])
}

model Manuscript {
  id             String         @id @default(cuid())
  title          String
  authorName     String?
  targetGenre    String?
  targetAudience String?
  originalFileUrl String?
  originalText   String?
  sourceFileName String
  sourceMimeType String?
  sourceFormat   ManuscriptFormat
  wordCount      Int            @default(0)
  chapterCount   Int            @default(0)
  paragraphCount Int            @default(0)
  chunkCount     Int            @default(0)
  status         String         @default("UPLOADED")
  analysisStatus AnalysisStatus @default(NOT_STARTED)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  chapters     ManuscriptChapter[]
  scenes       Scene[]
  paragraphs   Paragraph[]
  chunks       ManuscriptChunk[]
  profile      ManuscriptProfile?
  runs         AnalysisRun[]
  reports      AuditReport[]
  rewrites     ChapterRewrite[]
  versions     ManuscriptVersion[]
  outputs      AnalysisOutput[]
  findings     Finding[]
  rewritePlans RewritePlan[]
  pipelineJobs PipelineJob[]
  decisions    EditorialDecision[]

  @@index([createdAt])
  @@index([analysisStatus])
  @@index([status])
  @@index([targetGenre])
}

model ManuscriptVersion {
  id             String   @id @default(cuid())
  manuscriptId   String
  versionNumber  Int
  sourceText     String
  sourceHash     String
  parserVersion  String
  createdAt      DateTime @default(now())

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  @@unique([manuscriptId, versionNumber])
  @@index([sourceHash])
}

model ManuscriptChapter {
  id           String   @id @default(cuid())
  manuscriptId String
  order        Int
  chapterIndex Int      @default(0)
  title        String
  heading      String?
  text         String   @default("")
  summary      String?
  wordCount    Int      @default(0)
  status       String   @default("PENDING")
  startOffset  Int?
  endOffset    Int?
  createdAt    DateTime @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  scenes     Scene[]
  paragraphs Paragraph[]
  chunks     ManuscriptChunk[]
  rewrites   ChapterRewrite[]
  findings   Finding[]
  decisions  EditorialDecision[]

  @@map("Chapter")
  @@unique([manuscriptId, order])
  @@index([manuscriptId])
  @@index([manuscriptId, chapterIndex])
  @@index([status])
}

model Scene {
  id           String   @id @default(cuid())
  manuscriptId String
  chapterId    String
  order        Int
  title        String
  wordCount    Int      @default(0)
  marker       String?
  createdAt    DateTime @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter    ManuscriptChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraphs Paragraph[]
  chunks     ManuscriptChunk[]

  @@unique([chapterId, order])
  @@index([manuscriptId])
}

model Paragraph {
  id                 String   @id @default(cuid())
  manuscriptId       String
  chapterId          String
  sceneId            String
  globalOrder        Int
  chapterOrder       Int
  sceneOrder         Int
  text               String
  wordCount          Int      @default(0)
  approximateOffset  Int?
  createdAt          DateTime @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter    ManuscriptChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene      Scene             @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([manuscriptId, globalOrder])
  @@index([chapterId])
  @@index([sceneId])
}

model ManuscriptChunk {
  id                 String                     @id @default(cuid())
  manuscriptId       String
  chapterId          String
  sceneId            String?
  chunkIndex         Int
  text               String
  wordCount          Int                        @default(0)
  startParagraph     Int
  endParagraph       Int
  paragraphStart     Int?
  paragraphEnd       Int?
  tokenEstimate      Int                        @default(0)
  tokenCount         Int                        @default(0)
  metadata           Json?
  localMetrics       Json?
  summary            String?
  embedding          Unsupported("vector(1536)")?
  createdAt          DateTime                   @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter    ManuscriptChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene      Scene?            @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  outputs    AnalysisOutput[]
  findings   Finding[]

  @@unique([manuscriptId, chunkIndex])
  @@index([manuscriptId])
  @@index([chapterId])
}

model ManuscriptProfile {
  id                       String   @id @default(cuid())
  manuscriptId             String   @unique
  wordCount                Int      @default(0)
  chapterCount             Int      @default(0)
  avgChapterWords          Int      @default(0)
  medianChapterWords       Int      @default(0)
  minChapterWords          Int      @default(0)
  maxChapterWords          Int      @default(0)
  avgSentenceLength        Float    @default(0)
  dialogueRatio            Float    @default(0)
  questionRatio            Float    @default(0)
  exclamationRatio         Float    @default(0)
  expositionRatio          Float    @default(0)
  actionRatio              Float    @default(0)
  introspectionRatio       Float    @default(0)
  lexicalDensity           Float    @default(0)
  paragraphLengthDistribution Json?
  sentenceLengthDistribution  Json?
  repeatedTerms            Json?
  chapterLengthCurve       Json?
  povEstimate              String?
  tenseEstimate            String?
  openingHookType          String?
  pacingCurve              Json?
  emotionalIntensityCurve  Json?
  conflictDensityCurve     Json?
  chapterEndingPatterns    Json?
  dominantSceneModes       Json?
  narrativeDistance        String?
  styleFingerprint         Json?
  dialogueStyle            Json?
  expositionStyle          Json?
  genreMarkers             Json?
  tropeMarkers             Json?
  literaryCraftLessons     Json?
  deterministicMetrics     Json?
  aiMetrics                Json?
  createdAt                DateTime @default(now())

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
}

model AnalysisRun {
  id           String            @id @default(cuid())
  manuscriptId String
  type         AnalysisRunType   @default(FULL_AUDIT)
  status       AnalysisRunStatus @default(RUNNING)
  model        String?
  currentPass  AnalysisPassType?
  globalMemory Json?
  checkpoint   Json?
  metadata     Json?
  error        String?
  startedAt    DateTime          @default(now())
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  manuscript   Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  outputs      AnalysisOutput[]
  report       AuditReport?
  rewrites     ChapterRewrite[]
  findings     Finding[]
  rewritePlans RewritePlan[]

  @@index([manuscriptId, status])
  @@index([manuscriptId, type])
}

model AnalysisOutput {
  id             String               @id @default(cuid())
  runId          String
  manuscriptId   String
  passType       AnalysisPassType
  scopeType      String
  scopeId        String
  chunkId        String?
  chapterId      String?
  promptVersion  String
  model          String
  inputSummary   Json?
  output         Json
  rawText        String?
  status         AnalysisOutputStatus @default(COMPLETED)
  error          String?
  createdAt      DateTime             @default(now())

  run        AnalysisRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  manuscript Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chunk      ManuscriptChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@unique([runId, passType, scopeType, scopeId])
  @@index([manuscriptId, passType])
  @@index([chunkId])
}

model AuditReport {
  id               String   @id @default(cuid())
  manuscriptId     String
  runId            String   @unique
  executiveSummary String
  topIssues        Json
  chapterNotes     Json
  rewriteStrategy  String
  structured       Json
  markdown         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  run        AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([manuscriptId])
}

model Finding {
  id                 String   @id @default(cuid())
  analysisRunId      String
  manuscriptId       String
  chapterId          String?
  chunkId            String?
  issueType          String
  severity           Int
  confidence         Float
  problem            String
  evidence           String?
  recommendation     String
  rewriteInstruction String?
  createdAt          DateTime @default(now())

  analysisRun AnalysisRun        @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  manuscript  Manuscript         @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter     ManuscriptChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  chunk       ManuscriptChunk?   @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  decisions   EditorialDecision[]

  @@index([analysisRunId])
  @@index([manuscriptId])
  @@index([chapterId])
  @@index([chunkId])
  @@index([issueType])
  @@index([severity])
}

model RewritePlan {
  id                String   @id @default(cuid())
  manuscriptId      String
  analysisRunId     String
  globalStrategy    String
  chapterPlans      Json
  continuityRules   Json
  styleRules        Json
  marketPositioning Json
  createdAt         DateTime @default(now())

  manuscript      Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  analysisRun     AnalysisRun      @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  chapterRewrites ChapterRewrite[]
  decisions        EditorialDecision[]

  @@index([manuscriptId])
  @@index([analysisRunId])
}

model EditorialDecision {
  id            String                  @id @default(cuid())
  manuscriptId  String
  chapterId     String?
  findingId     String?
  rewritePlanId String?
  title         String
  rationale     String?
  status        EditorialDecisionStatus @default(NEEDS_REVIEW)
  scope         EditorialDecisionScope  @default(CHAPTER)
  metadata      Json?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  manuscript  Manuscript         @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter     ManuscriptChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  finding     Finding?           @relation(fields: [findingId], references: [id], onDelete: SetNull)
  rewritePlan RewritePlan?       @relation(fields: [rewritePlanId], references: [id], onDelete: SetNull)

  @@index([manuscriptId])
  @@index([chapterId])
  @@index([findingId])
  @@index([rewritePlanId])
  @@index([status])
  @@index([scope])
}

model ChapterRewrite {
  id              String   @id @default(cuid())
  manuscriptId    String
  chapterId       String
  runId           String?
  rewritePlanId   String?
  version         Int      @default(1)
  originalText    String   @default("")
  rewrittenText   String   @default("")
  changeLog       Json?
  continuityNotes Json?
  status          String   @default("DRAFT")
  promptVersion   String   @default("v2")
  model           String   @default("stub")
  sourceSummary   Json?
  content         String   @default("")
  rationale       Json?
  createdAt       DateTime @default(now())

  manuscript  Manuscript         @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter     ManuscriptChapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  run         AnalysisRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)
  rewritePlan RewritePlan?       @relation(fields: [rewritePlanId], references: [id], onDelete: SetNull)

  @@index([manuscriptId])
  @@index([chapterId])
  @@index([rewritePlanId])
  @@index([status])
}

model ManuscriptNode {
  id             String   @id @default(cuid())
  manuscriptId   String
  parentId       String?
  key            String   @unique
  type           String
  order          Int
  title          String?
  chapterId      String?
  sceneId        String?
  chunkId        String?
  paragraphStart Int?
  paragraphEnd   Int?
  textHash       String?
  wordCount      Int      @default(0)
  summaryShort   String?
  summaryLong    String?
  metrics        Json?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([manuscriptId])
  @@index([parentId])
  @@index([type])
  @@index([chapterId])
  @@index([sceneId])
  @@index([chunkId])
  @@index([manuscriptId, type])
  @@index([manuscriptId, order])
}

model CompilerArtifact {
  id              String   @id @default(cuid())
  manuscriptId    String
  nodeId          String?
  chapterId       String?
  sceneId         String?
  chunkId         String?
  artifactType    String
  model           String
  reasoningEffort String
  promptVersion   String
  inputHash       String
  output          Json
  rawText         String?
  status          String   @default("COMPLETED")
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([manuscriptId, artifactType, inputHash])
  @@index([manuscriptId])
  @@index([nodeId])
  @@index([chapterId])
  @@index([sceneId])
  @@index([chunkId])
  @@index([artifactType])
  @@index([manuscriptId, artifactType])
  @@index([inputHash])
}

model NarrativeFact {
  id                String   @id @default(cuid())
  manuscriptId      String
  nodeId            String?
  chapterId         String?
  sceneId           String?
  factType          String
  subject           String?
  predicate         String?
  object            String?
  factText          String
  status            String   @default("ACTIVE")
  confidence        Float    @default(0.5)
  sourceTextSnippet String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([manuscriptId])
  @@index([nodeId])
  @@index([chapterId])
  @@index([sceneId])
  @@index([factType])
  @@index([subject])
  @@index([status])
}

model CharacterState {
  id                String   @id @default(cuid())
  manuscriptId      String
  nodeId            String?
  chapterId         String?
  sceneId           String?
  characterName     String
  canonicalName     String?
  goals             Json?
  fears             Json?
  knowledge         Json?
  secrets           Json?
  relationships     Json?
  emotionalState    String?
  deltaFromPrevious String?
  confidence        Float    @default(0.5)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([manuscriptId])
  @@index([canonicalName])
  @@index([characterName])
  @@index([chapterId])
  @@index([sceneId])
  @@index([nodeId])
}

model PlotEvent {
  id                 String   @id @default(cuid())
  manuscriptId       String
  nodeId             String?
  chapterId          String?
  sceneId            String?
  eventText          String
  cause              String?
  consequence        String?
  opensThread        String?
  closesThread       String?
  stakes             String?
  affectedCharacters Json?
  confidence         Float    @default(0.5)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([manuscriptId])
  @@index([chapterId])
  @@index([sceneId])
  @@index([nodeId])
}

model StyleFingerprint {
  id                  String   @id @default(cuid())
  manuscriptId        String
  nodeId              String?
  chapterId           String?
  sceneId             String?
  scopeType           String
  povEstimate         String?
  tenseEstimate       String?
  narrativeDistance   String?
  dialogueRatio       Float    @default(0)
  avgSentenceLength   Float    @default(0)
  dominantModes       Json?
  voiceRules          Json?
  metrics             Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([manuscriptId])
  @@index([nodeId])
  @@index([chapterId])
  @@index([sceneId])
  @@index([scopeType])
}

model PipelineJob {
  id             String    @id @default(cuid())
  manuscriptId   String?
  chapterId      String?
  type           String
  status         String    @default("QUEUED")
  idempotencyKey String    @unique
  dependencyIds  Json?
  readyAt        DateTime?
  lockedAt       DateTime?
  lockedBy       String?
  lockExpiresAt  DateTime?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  error          String?
  metadata       Json?
  result         Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  manuscript Manuscript? @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  @@index([manuscriptId])
  @@index([chapterId])
  @@index([type])
  @@index([status])
  @@index([readyAt])
  @@index([lockedAt])
  @@index([lockExpiresAt])
  @@index([manuscriptId, status])
}

model InngestEventLog {
  id           String   @id @default(cuid())
  eventName    String
  manuscriptId String?
  jobId        String?
  payload      Json
  status       String   @default("SENT")
  error        String?
  createdAt    DateTime @default(now())

  @@index([eventName])
  @@index([manuscriptId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model WorkerHeartbeat {
  id         String   @id @default(cuid())
  workerType String
  status     String
  lastSeenAt DateTime @default(now())
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([workerType])
  @@index([status])
  @@index([lastSeenAt])
}
