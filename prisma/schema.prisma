generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum ManuscriptFormat {
  TXT
  DOCX
}

enum AnalysisStatus {
  NOT_STARTED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisOutputStatus {
  COMPLETED
  FAILED
}

enum AnalysisPassType {
  PREMISE_GENRE
  STRUCTURE
  PACING
  CHARACTER
  PROSE_STYLE
  COMMERCIAL_MARKET_FIT
  SYNTHESIS
  REWRITE
  CHUNK_ANALYSIS
  CHAPTER_AUDIT
  WHOLE_BOOK_AUDIT
  CORPUS_COMPARISON
  TREND_COMPARISON
  REWRITE_PLAN
  CHAPTER_REWRITE
}

enum AnalysisRunType {
  FULL_AUDIT
  CHAPTER_AUDIT
  CORPUS_COMPARISON
  TREND_COMPARISON
  REWRITE_PLAN
  CHAPTER_REWRITE
}

enum SourceType {
  GUTENBERG
  LITTERATURBANKEN
  SPRAKBANKEN
  DOAB
  GOOGLE_BOOKS
  NYT_BOOKS
  MANUAL
  PRIVATE
}

enum RightsStatus {
  PUBLIC_DOMAIN
  OPEN_LICENSE
  LICENSED
  PRIVATE_REFERENCE
  METADATA_ONLY
  UNKNOWN
}

enum CorpusIngestionStatus {
  QUEUED
  IMPORTED
  CHUNKED
  PROFILED
  FAILED
  METADATA_ONLY
}

enum CorpusAnalysisStatus {
  NOT_STARTED
  RUNNING
  COMPLETED
  FAILED
}

model Source {
  id          String     @id @default(cuid())
  name        String
  type        SourceType
  baseUrl     String?
  rightsNotes String?
  createdAt   DateTime   @default(now())

  books CorpusBook[]

  @@index([type])
}

model CorpusBook {
  id                String                 @id @default(cuid())
  sourceId          String
  title             String
  author            String?
  language          String?
  publicationYear   Int?
  genre             String?
  sourceUrl         String?
  rightsStatus      RightsStatus           @default(UNKNOWN)
  licenseType       String?
  allowedUses       Json?
  fullTextAvailable Boolean                @default(false)
  ingestionStatus   CorpusIngestionStatus  @default(QUEUED)
  analysisStatus    CorpusAnalysisStatus   @default(NOT_STARTED)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  source  Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  text    CorpusBookText?
  chunks  CorpusChunk[]
  profile BookProfile?

  @@index([sourceId])
  @@index([rightsStatus])
  @@index([ingestionStatus])
  @@index([analysisStatus])
  @@index([genre])
  @@index([language])
}

model CorpusBookText {
  id          String   @id @default(cuid())
  bookId      String   @unique
  rawText     String
  cleanedText String
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model CorpusChunk {
  id             String                     @id @default(cuid())
  bookId         String
  chapterIndex   Int?
  sectionIndex   Int?
  paragraphIndex Int?
  chunkIndex     Int
  text           String
  tokenCount     Int                        @default(0)
  embedding      Unsupported("vector(1536)")?
  summary        String?
  metrics        Json?
  createdAt      DateTime                   @default(now())

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, chunkIndex])
  @@index([bookId])
  @@index([chapterIndex])
}

model BookProfile {
  id                       String   @id @default(cuid())
  bookId                   String   @unique
  wordCount                Int      @default(0)
  chapterCount             Int      @default(0)
  avgChapterWords          Int      @default(0)
  avgSentenceLength        Float    @default(0)
  dialogueRatio            Float    @default(0)
  expositionRatio          Float    @default(0)
  actionRatio              Float    @default(0)
  introspectionRatio       Float    @default(0)
  lexicalDensity           Float    @default(0)
  povEstimate              String?
  tenseEstimate            String?
  openingHookType          String?
  pacingCurve              Json?
  emotionalIntensityCurve  Json?
  conflictDensityCurve     Json?
  chapterEndingPatterns    Json?
  styleFingerprint         Json?
  genreMarkers             Json?
  tropeMarkers             Json?
  createdAt                DateTime @default(now())

  book CorpusBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model TrendSignal {
  id            String   @id @default(cuid())
  source        String
  title         String?
  author        String?
  genre         String?
  category      String?
  rank          Int?
  listName      String?
  signalDate    DateTime?
  description   String?
  blurb         String?
  reviewSnippet String?
  externalUrl   String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([source])
  @@index([genre])
  @@index([category])
  @@index([signalDate])
  @@index([rank])
}

model Manuscript {
  id             String         @id @default(cuid())
  title          String
  authorName     String?
  targetGenre    String?
  targetAudience String?
  originalFileUrl String?
  originalText   String?
  sourceFileName String
  sourceMimeType String?
  sourceFormat   ManuscriptFormat
  wordCount      Int            @default(0)
  chapterCount   Int            @default(0)
  paragraphCount Int            @default(0)
  chunkCount     Int            @default(0)
  status         String         @default("UPLOADED")
  analysisStatus AnalysisStatus @default(NOT_STARTED)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  chapters     ManuscriptChapter[]
  scenes       Scene[]
  paragraphs   Paragraph[]
  chunks       ManuscriptChunk[]
  profile      ManuscriptProfile?
  runs         AnalysisRun[]
  reports      AuditReport[]
  rewrites     ChapterRewrite[]
  versions     ManuscriptVersion[]
  outputs      AnalysisOutput[]
  findings     Finding[]
  rewritePlans RewritePlan[]

  @@index([createdAt])
  @@index([analysisStatus])
  @@index([status])
  @@index([targetGenre])
}

model ManuscriptVersion {
  id             String   @id @default(cuid())
  manuscriptId   String
  versionNumber  Int
  sourceText     String
  sourceHash     String
  parserVersion  String
  createdAt      DateTime @default(now())

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  @@unique([manuscriptId, versionNumber])
  @@index([sourceHash])
}

model ManuscriptChapter {
  id           String   @id @default(cuid())
  manuscriptId String
  order        Int
  chapterIndex Int      @default(0)
  title        String
  heading      String?
  text         String   @default("")
  summary      String?
  wordCount    Int      @default(0)
  status       String   @default("PENDING")
  startOffset  Int?
  endOffset    Int?
  createdAt    DateTime @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  scenes     Scene[]
  paragraphs Paragraph[]
  chunks     ManuscriptChunk[]
  rewrites   ChapterRewrite[]
  findings   Finding[]

  @@map("Chapter")
  @@unique([manuscriptId, order])
  @@index([manuscriptId])
  @@index([manuscriptId, chapterIndex])
  @@index([status])
}

model Scene {
  id           String   @id @default(cuid())
  manuscriptId String
  chapterId    String
  order        Int
  title        String
  wordCount    Int      @default(0)
  marker       String?
  createdAt    DateTime @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter    ManuscriptChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  paragraphs Paragraph[]
  chunks     ManuscriptChunk[]

  @@unique([chapterId, order])
  @@index([manuscriptId])
}

model Paragraph {
  id                 String   @id @default(cuid())
  manuscriptId       String
  chapterId          String
  sceneId            String
  globalOrder        Int
  chapterOrder       Int
  sceneOrder         Int
  text               String
  wordCount          Int      @default(0)
  approximateOffset  Int?
  createdAt          DateTime @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter    ManuscriptChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene      Scene             @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([manuscriptId, globalOrder])
  @@index([chapterId])
  @@index([sceneId])
}

model ManuscriptChunk {
  id                 String                     @id @default(cuid())
  manuscriptId       String
  chapterId          String
  sceneId            String?
  chunkIndex         Int
  text               String
  wordCount          Int                        @default(0)
  startParagraph     Int
  endParagraph       Int
  paragraphStart     Int?
  paragraphEnd       Int?
  tokenEstimate      Int                        @default(0)
  tokenCount         Int                        @default(0)
  metadata           Json?
  localMetrics       Json?
  summary            String?
  embedding          Unsupported("vector(1536)")?
  createdAt          DateTime                   @default(now())

  manuscript Manuscript        @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter    ManuscriptChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene      Scene?            @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  outputs    AnalysisOutput[]
  findings   Finding[]

  @@unique([manuscriptId, chunkIndex])
  @@index([manuscriptId])
  @@index([chapterId])
}

model ManuscriptProfile {
  id                       String   @id @default(cuid())
  manuscriptId             String   @unique
  wordCount                Int      @default(0)
  chapterCount             Int      @default(0)
  avgChapterWords          Int      @default(0)
  avgSentenceLength        Float    @default(0)
  dialogueRatio            Float    @default(0)
  expositionRatio          Float    @default(0)
  actionRatio              Float    @default(0)
  introspectionRatio       Float    @default(0)
  pacingCurve              Json?
  emotionalIntensityCurve  Json?
  conflictDensityCurve     Json?
  styleFingerprint         Json?
  genreMarkers             Json?
  tropeMarkers             Json?
  createdAt                DateTime @default(now())

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
}

model AnalysisRun {
  id           String            @id @default(cuid())
  manuscriptId String
  type         AnalysisRunType   @default(FULL_AUDIT)
  status       AnalysisRunStatus @default(RUNNING)
  model        String?
  currentPass  AnalysisPassType?
  globalMemory Json?
  checkpoint   Json?
  metadata     Json?
  error        String?
  startedAt    DateTime          @default(now())
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  manuscript   Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  outputs      AnalysisOutput[]
  report       AuditReport?
  rewrites     ChapterRewrite[]
  findings     Finding[]
  rewritePlans RewritePlan[]

  @@index([manuscriptId, status])
  @@index([manuscriptId, type])
}

model AnalysisOutput {
  id             String               @id @default(cuid())
  runId          String
  manuscriptId   String
  passType       AnalysisPassType
  scopeType      String
  scopeId        String
  chunkId        String?
  chapterId      String?
  promptVersion  String
  model          String
  inputSummary   Json?
  output         Json
  rawText        String?
  status         AnalysisOutputStatus @default(COMPLETED)
  error          String?
  createdAt      DateTime             @default(now())

  run        AnalysisRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  manuscript Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chunk      ManuscriptChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@unique([runId, passType, scopeType, scopeId])
  @@index([manuscriptId, passType])
  @@index([chunkId])
}

model AuditReport {
  id               String   @id @default(cuid())
  manuscriptId     String
  runId            String   @unique
  executiveSummary String
  topIssues        Json
  chapterNotes     Json
  rewriteStrategy  String
  structured       Json
  markdown         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  manuscript Manuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  run        AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([manuscriptId])
}

model Finding {
  id                 String   @id @default(cuid())
  analysisRunId      String
  manuscriptId       String
  chapterId          String?
  chunkId            String?
  issueType          String
  severity           Int
  confidence         Float
  problem            String
  evidence           String?
  recommendation     String
  rewriteInstruction String?
  createdAt          DateTime @default(now())

  analysisRun AnalysisRun        @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  manuscript  Manuscript         @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter     ManuscriptChapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  chunk       ManuscriptChunk?   @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@index([analysisRunId])
  @@index([manuscriptId])
  @@index([chapterId])
  @@index([chunkId])
  @@index([issueType])
  @@index([severity])
}

model RewritePlan {
  id                String   @id @default(cuid())
  manuscriptId      String
  analysisRunId     String
  globalStrategy    String
  chapterPlans      Json
  continuityRules   Json
  styleRules        Json
  marketPositioning Json
  createdAt         DateTime @default(now())

  manuscript      Manuscript       @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  analysisRun     AnalysisRun      @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  chapterRewrites ChapterRewrite[]

  @@index([manuscriptId])
  @@index([analysisRunId])
}

model ChapterRewrite {
  id              String   @id @default(cuid())
  manuscriptId    String
  chapterId       String
  runId           String?
  rewritePlanId   String?
  version         Int      @default(1)
  originalText    String   @default("")
  rewrittenText   String   @default("")
  changeLog       Json?
  continuityNotes Json?
  status          String   @default("DRAFT")
  promptVersion   String   @default("v2")
  model           String   @default("stub")
  sourceSummary   Json?
  content         String   @default("")
  rationale       Json?
  createdAt       DateTime @default(now())

  manuscript  Manuscript         @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  chapter     ManuscriptChapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  run         AnalysisRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)
  rewritePlan RewritePlan?       @relation(fields: [rewritePlanId], references: [id], onDelete: SetNull)

  @@index([manuscriptId])
  @@index([chapterId])
  @@index([rewritePlanId])
  @@index([status])
}
