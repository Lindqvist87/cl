# Required for local development and Vercel
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/manuscript_audit?schema=public"
OPENAI_API_KEY=""
EXTRACTION_MODEL="gpt-5.4-nano"
EXTRACTION_REASONING_EFFORT="low"
AUDIT_MODEL="gpt-5.4-mini"
AUDIT_REASONING_EFFORT="medium"
SCENE_ANALYSIS_MODEL="gpt-5.4-mini"
SCENE_ANALYSIS_REASONING_EFFORT="medium"
CHAPTER_COMPILER_MODEL="gpt-5.4"
CHAPTER_COMPILER_REASONING_EFFORT="high"
WHOLE_BOOK_COMPILER_MODEL="gpt-5.4"
WHOLE_BOOK_COMPILER_REASONING_EFFORT="xhigh"
CHIEF_EDITOR_MODEL="gpt-5.4"
CHIEF_EDITOR_REASONING_EFFORT="xhigh"
OPENAI_REWRITE_MODEL="gpt-5.4"
REWRITE_REASONING_EFFORT="high"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
ADMIN_JOB_TOKEN=""
AUTO_GENERATE_FULL_BOOK_REWRITES="false"
ENABLE_INNGEST_WORKER="false"
SHOW_OPERATOR_TOOLS="false"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Optional app/runtime configuration
NEXT_PUBLIC_APP_NAME="Manuscript Audit"
INNGEST_APP_ID="manuscript-intelligence-app"
INNGEST_SERVE_ORIGIN=""
MAX_JOBS_PER_INNGEST_RUN="3"
MAX_SECONDS_PER_INNGEST_RUN="25"

# Legacy model fallbacks if the role-based variables above are unset
# OPENAI_AUDIT_MODEL="gpt-5.4-mini"
# OPENAI_EDITOR_MODEL="gpt-5.4-mini"

# Optional cost-estimate rates
# OPENAI_INPUT_COST_PER_MILLION_TOKENS_USD="0"
# OPENAI_OUTPUT_COST_PER_MILLION_TOKENS_USD="0"

# Optional build/local helper flags
# DATABASE_URL_UNPOOLED=""
# SKIP_PRISMA_MIGRATE="1" # only set when migrations are applied outside the build
# INNGEST_DEV="1"
# APP_URL="http://localhost:3000"
# MANUSCRIPT_ID=""
# MAX_JOBS="3"
# MAX_SECONDS="25"
