# Required for local development and Vercel
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/manuscript_audit?schema=public"
OPENAI_API_KEY=""
OPENAI_AUDIT_MODEL="gpt-5.4-mini"
OPENAI_REWRITE_MODEL="gpt-5.5"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
ENABLE_INNGEST_WORKER="false"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Optional app/runtime configuration
NEXT_PUBLIC_APP_NAME="Manuscript Audit"
INNGEST_APP_ID="manuscript-intelligence-app"
INNGEST_SERVE_ORIGIN=""
MAX_JOBS_PER_INNGEST_RUN="3"
MAX_SECONDS_PER_INNGEST_RUN="25"

# Legacy fallback if OPENAI_AUDIT_MODEL is unset
# OPENAI_EDITOR_MODEL="gpt-5.4-mini"

# Optional cost-estimate rates
# OPENAI_INPUT_COST_PER_MILLION_TOKENS_USD="0"
# OPENAI_OUTPUT_COST_PER_MILLION_TOKENS_USD="0"

# Optional build/local helper flags
# SKIP_PRISMA_MIGRATE="1"
# INNGEST_DEV="1"
# APP_URL="http://localhost:3000"
# MANUSCRIPT_ID=""
# MAX_JOBS="3"
# MAX_SECONDS="25"
