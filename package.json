{
  "name": "manuscript-audit-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/apply-migrations-if-configured.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test tests/parsing.test.ts tests/chunking.test.ts tests/chapterContext.test.ts tests/pipelineSteps.test.ts tests/pipelineJobs.test.ts tests/inngestEvents.test.ts tests/continuity.test.ts tests/exports.test.ts tests/rightsAndUsage.test.ts tests/corpusOnboarding.test.ts tests/corpusComparisonRewrite.test.ts",
    "typecheck": "tsc --noEmit",
    "inngest:dev": "npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "jobs:run-next": "node scripts/run-job-endpoint.mjs run-next",
    "jobs:run-until-idle": "node scripts/run-job-endpoint.mjs run-until-idle",
    "pipeline:resume": "node scripts/run-job-endpoint.mjs kick-inngest",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "docx": "^9.1.1",
    "inngest": "^4.2.5",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.8.0",
    "next": "^15.1.0",
    "openai": "^4.76.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
